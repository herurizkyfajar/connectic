sequenceDiagram
    actor Admin
    participant View as Form LMS
    participant Controller as LmsController
    participant Model as Lms Model
    participant Storage as File System

    Admin->>View: Input Materi Baru
    View->>Controller: POST /admin/lms
    
    alt Slug Kosong
        Controller->>Controller: Generate Slug from Title
    end

    alt Ada Cover Image
        Controller->>Storage: Store Image
        Storage-->>Controller: Return Path
    end

    Controller->>Model: Create(Data)
    Model-->>Controller: Success
    Controller-->>View: Redirect Success

    Admin->>View: Lihat Detail Materi
    View->>Controller: GET /admin/lms/{id}
    Controller->>Model: Find LMS with Readers
    Model-->>Controller: Return LMS & Readers List
    Controller-->>View: Show Content & Reader List

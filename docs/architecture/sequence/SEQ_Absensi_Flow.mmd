sequenceDiagram
    actor Anggota
    participant View as View Absensi
    participant Controller as AbsensiKegiatanController
    participant Model as AbsensiKegiatan Model
    participant Storage as File Storage
    participant DB as Database
    
    Anggota->>View: Buka Form Absensi
    View->>Controller: GET /create
    Controller->>View: Show Form (List Kegiatan Terlaksana)
    
    Anggota->>View: Pilih Kegiatan, Upload Bukti
    View->>Controller: POST /store
    
    Controller->>Model: Check Duplicate (Anggota + Kegiatan)
    alt Already Exists
        Controller-->>View: Error "Sudah Absen"
    else New Absensi
        opt Upload Bukti
            Controller->>Storage: Put File
            Storage-->>Controller: Path
        end
        
        Controller->>Model: Create(Data)
        Model->>DB: Insert
        DB-->>Model: Success
        Controller-->>View: Redirect Success
    end

sequenceDiagram
    actor Admin
    participant View as View Index
    participant Controller as AdminAnggotaAccessController
    participant Model as Anggota Model
    participant DB as Database
    
    Admin->>View: Buka Menu Akses Anggota
    View->>Controller: GET /admin/anggota-access
    Controller->>Model: Anggota::count()
    Controller->>Model: Anggota::paginate()
    Model-->>Controller: Return Data
    Controller-->>View: Render List Anggota
    
    par Toggle Status
        Admin->>View: Klik Toggle Status (Aktif/Nonaktif)
        View->>Controller: POST /toggle-status/{id}
        Controller->>Model: Find & Update Status
        Model->>DB: UPDATE anggotas SET status = ...
        DB-->>Model: Success
        Controller-->>View: Redirect with Success Message
    and Reset Password
        Admin->>View: Klik Reset Password
        View->>Controller: POST /reset-password/{id}
        Controller->>Model: Find & Update Password
        Model->>DB: UPDATE anggotas SET password = Hash('password123')
        DB-->>Model: Success
        Controller-->>View: Redirect with Message
    and Bulk Action
        Admin->>View: Select Multiple -> Pilih Aksi -> Submit
        View->>Controller: POST /bulk-action
        Controller->>Model: whereIn('id', ids)->update(...)
        Model->>DB: Batch Update
        DB-->>Model: Success
        Controller-->>View: Redirect with Summary Message
    end

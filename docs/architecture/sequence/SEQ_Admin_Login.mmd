sequenceDiagram
    actor Admin
    participant View as Login Page
    participant Controller as AdminAuthController
    participant Model as Admin Model
    participant DB as Database

    Admin->>View: Buka Halaman Login
    View->>Admin: Tampilkan Form Login
    Admin->>View: Input Username & Password
    View->>Controller: POST /admin/login
    Controller->>Model: Cek Kredensial
    Model->>DB: Query User
    DB-->>Model: Return User Data
    Model-->>Controller: Return Result
    
    alt Login Sukses
        Controller->>View: Redirect ke Dashboard
        View-->>Admin: Tampilkan Dashboard
    else Login Gagal
        Controller->>View: Return Error Message
        View-->>Admin: Tampilkan Pesan Error
    end

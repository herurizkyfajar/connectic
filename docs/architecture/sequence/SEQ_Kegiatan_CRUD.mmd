sequenceDiagram
    actor Admin
    participant View as View Kegiatan
    participant Controller as RiwayatKegiatanController
    participant Model as RiwayatKegiatan Model
    participant AbsenModel as AbsensiKegiatan Model
    participant Storage as File Storage
    participant DB as Database
    
    Admin->>View: Input Data Kegiatan
    View->>Controller: POST /store
    
    opt Upload Dokumentasi
        Controller->>Storage: Put File
        Storage-->>Controller: Path
    end
    
    Controller->>Model: Create(Data)
    Model->>DB: Insert
    DB-->>Model: Success
    Controller-->>View: Redirect Success
    
    opt Input Absensi Manual (Bulk)
        Admin->>View: Form Absensi (Select Multiple Anggota)
        View->>Controller: POST /store-absensi/{id}
        
        loop For Each Anggota
            Controller->>AbsenModel: Check Exists?
            alt Not Exists
                Controller->>AbsenModel: Create Absensi
                AbsenModel->>DB: Insert
            end
        end
        
        Controller-->>View: Redirect with Result (Success/Failed Count)
    end
